@model IEnumerable<Webbanhang.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-boxes text-primary"></i> Quản lý sản phẩm</h2>
        <a asp-action="Add" class="btn btn-primary">
            <i class="fas fa-plus"></i> Thêm sản phẩm mới
        </a>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 100px;">Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá bán</th>
                    <th>Mô tả</th>
                    <th>Danh mục</th>
                    <th class="text-center" style="width: 220px;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="rounded" style="width: 70px; height: 70px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                                    <i class="fas fa-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-bold text-dark">@product.Name</td>
                        <td class="text-danger fw-bold">@product.Price.ToString("N0") ₫</td>
                        <td class="text-muted text-truncate" style="max-width: 250px;">@product.Description</td>
                        <td>
                            <span class="badge bg-secondary">@product.Category?.Name</span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group gap-1">
                                <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                                    <i class="fas fa-eye"></i> Chi tiết
                                </a>
                                <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-sm btn-outline-warning" title="Sửa">
                                    <i class="fas fa-edit"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger" title="Xóa">
                                    <i class="fas fa-trash"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>