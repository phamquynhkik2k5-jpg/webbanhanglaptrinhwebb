@model Webbanhang.Models.Product

@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="container mt-4 slide-in">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-edit"></i> Chỉnh sửa thông tin sản phẩm</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Update" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">Giá bán (₫)</label>
                                <input asp-for="Price" type="number" class="form-control" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-bold">Danh mục</label>
                                <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-select"></select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row border p-3 rounded bg-light mb-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-primary">Thay đổi ảnh đại diện</label>
                                <input type="file" name="imageUrl" class="form-control mb-2" accept="image/*" />
                                <small class="text-muted d-block mb-2">Ảnh hiện tại:</small>
                                <img src="@Model.ImageUrl" alt="Ảnh hiện tại" class="img-thumbnail rounded" style="max-height: 120px;" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-success">Bổ sung thêm ảnh phụ</label>
                                <input type="file" name="imageUrls" class="form-control" multiple accept="image/*" />
                                <small class="text-muted d-block mt-2">* Các ảnh phụ cũ vẫn sẽ được giữ nguyên trong cơ sở dữ liệu.</small>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end border-top pt-3">
                            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                            <button type="submit" class="btn btn-warning px-4 text-dark fw-bold">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}