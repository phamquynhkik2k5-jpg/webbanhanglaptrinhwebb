@model Webbanhang.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container mt-5 fade-in">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-exclamation-triangle"></i> Cảnh báo hành động xóa!</h5>
                </div>
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded-circle border border-danger p-1" style="width: 120px; height: 120px; object-fit: cover;" />
                        }
                    else
                    {
                        <i class="fas fa-box border border-danger rounded-circle p-4 text-danger mb-2" style="font-size: 3rem;"></i>
                    }
                    </div>
                    
                    <h4 class="text-dark fw-bold mb-3">@Model.Name</h4>
                    <p class="text-muted">Bạn có chắc chắn muốn xóa vĩnh viễn sản phẩm này cùng toàn bộ hình ảnh đi kèm ra khỏi hệ thống không? Thao tác này không thể hoàn tác.</p>
                    
                    <form asp-action="Delete" method="post" class="mt-4 border-top pt-3 d-flex gap-2 justify-content-center">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-secondary px-4">Hủy bỏ</a>
                        <button type="submit" class="btn btn-danger px-4 fw-bold">Xác nhận xóa</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>