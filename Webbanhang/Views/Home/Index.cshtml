@model List<Webbanhang.Models.Product>

@{
    ViewData["Title"] = "Trang chủ - Webbanhang";
}

<style>
    .hero {
        background: linear-gradient(135deg, #0d6efd 0%, #4f8dfd 55%, #7aa7ff 100%);
        color: #fff;
        padding: 6rem 0;
        border-radius: 0 0 32px 32px;
        box-shadow: 0 14px 40px rgba(13, 110, 253, .25);
    }

        .hero .lead {
            color: rgba(255, 255, 255, .92);
        }

        .hero .btn {
            border-radius: 999px;
            padding-left: 1.25rem;
            padding-right: 1.25rem;
        }

    #products {
        background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
    }

    .product-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(20, 35, 90, .08);
        transition: transform .25s ease, box-shadow .25s ease;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 30px rgba(20, 35, 90, .16);
        }

    .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .35s ease;
    }

    .product-card:hover .product-image {
        transform: scale(1.05);
    }

    .product-price {
        color: #0d6efd;
        font-weight: 700;
        font-size: 1.05rem;
    }

    .soft-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 24px rgba(18, 38, 63, .08);
    }

    .section-title {
        font-weight: 700;
        color: #102a43;
    }

    .newsletter {
        background: linear-gradient(135deg, #1247d1 0%, #0d6efd 60%, #4f8dfd 100%);
    }

    .contact-info h5 i {
        width: 24px;
    }
</style>

<!-- Hero Section -->
<section class="hero fade-in">
    <div class="container text-center">
        <h1 class="fw-bold mb-3">Chào mừng đến Webbanhang</h1>
        <p class="lead">Khám phá những sản phẩm chất lượng cao với giá cạnh tranh nhất</p>
        <div class="mt-4 d-flex justify-content-center flex-wrap gap-2">
            <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg">
                <i class="fas fa-shopping-cart"></i> Mua sắm ngay
            </a>
            <a href="#about" class="btn btn-outline-light btn-lg">
                <i class="fas fa-info-circle"></i> Tìm hiểu thêm
            </a>
        </div>
    </div>
</section>

<!-- Products Section -->
<section id="products" class="py-5">
    <div class="container">
        <h2 class="text-center mb-5 section-title">
            <i class="fas fa-star text-warning"></i> Sản phẩm nổi bật
        </h2>

        @if (Model != null && Model.Count > 0)
        {
            <div class="row g-4">
                @foreach (var product in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card product-card h-100">
                            <div class="position-relative overflow-hidden" style="height: 250px; background-color: #eef2f7;">
                                @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="product-image" alt="@product.Name">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <i class="fas fa-image text-muted" style="font-size: 3rem;"></i>
                                    </div>
                                }
                                <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">
                                    <i class="fas fa-fire"></i> Hot
                                </span>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="card-title fw-semibold">@product.Name</h5>
                                <p class="card-text text-muted">
                                    @if (!string.IsNullOrWhiteSpace(product.Description))
                                    {
                                        @(product.Description.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)
                                    }
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="product-price">@product.Price.ToString("N0")₫</span>
                                    <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-primary btn-sm rounded-pill px-3">
                                        <i class="fas fa-eye"></i> Xem
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-5">
                <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4">
                    <i class="fas fa-eye"></i> Xem tất cả sản phẩm
                </a>
            </div>
        }
        else
        {
            <div class="alert alert-info text-center py-5 soft-card">
                <i class="fas fa-inbox fa-3x mb-3"></i>
                <h4>Chưa có sản phẩm</h4>
                <p>Hiện tại chúng tôi chưa có sản phẩm nào. Vui lòng quay lại sau!</p>
            </div>
        }
    </div>
</section>

<!-- About Section -->
<section id="about" class="py-5">
    <div class="container">
        <h2 class="text-center mb-5 section-title">Về chúng tôi</h2>
        <div class="row align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
                <div class="bg-white p-4 rounded-4 shadow-sm" style="height: 300px; display: flex; align-items: center; justify-content: center; border: 1px solid #eef2f7;">
                    <i class="fas fa-image text-muted" style="font-size: 5rem;"></i>
                </div>
            </div>
            <div class="col-md-6 ps-md-4">
                <h3 class="mb-3 fw-bold">Webbanhang - Nơi tin cậy của hàng triệu khách hàng</h3>
                <p>
                    Được thành lập vào năm 2020, Webbanhang đã trở thành một trong những nền tảng thương mại điện tử
                    hàng đầu tại Việt Nam. Chúng tôi cam kết cung cấp các sản phẩm chất lượng cao với giá cạnh tranh nhất.
                </p>
                <p>
                    Với đội ngũ chuyên nghiệp, chúng tôi luôn đặt khách hàng lên hàng đầu và không ngừng cải tiến
                    dịch vụ để mang lại trải nghiệm mua sắm tốt nhất.
                </p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check-circle text-success"></i> 1 triệu+ sản phẩm</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success"></i> 500K+ khách hàng hài lòng</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success"></i> Giao hàng toàn quốc</li>
                    <li><i class="fas fa-check-circle text-success"></i> Hỗ trợ 24/7</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Newsletter Section -->
<section class="py-5 text-white newsletter">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <h2 class="mb-3 fw-bold">Đăng ký nhận tin tức</h2>
                <p class="lead mb-4">Nhận những ưu đãi và thông tin sản phẩm mới trực tiếp vào email của bạn</p>
                <div class="input-group input-group-lg">
                    <input type="email" class="form-control border-0" placeholder="Nhập email của bạn...">
                    <button class="btn btn-warning text-dark fw-bold" type="button">
                        <i class="fas fa-paper-plane"></i> Đăng ký
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-5">
    <div class="container">
        <h2 class="text-center mb-5 section-title">Liên hệ chúng tôi</h2>
        <div class="row">
            <div class="col-md-6 mb-4">
                <h4 class="mb-3 fw-semibold">Gửi tin nhắn cho chúng tôi</h4>
                <form class="bg-white p-4 rounded-4 shadow-sm" style="border: 1px solid #eef2f7;">
                    <div class="mb-3">
                        <label for="name" class="form-label">Họ tên</label>
                        <input type="text" class="form-control" id="name" placeholder="Nhập họ tên của bạn">
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" placeholder="Nhập email của bạn">
                    </div>
                    <div class="mb-3">
                        <label for="message" class="form-label">Tin nhắn</label>
                        <textarea class="form-control" id="message" rows="5" placeholder="Nhập tin nhắn của bạn"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill">
                        <i class="fas fa-send"></i> Gửi tin nhắn
                    </button>
                </form>
            </div>
            <div class="col-md-6 contact-info">
                <h4 class="mb-4 fw-semibold">Thông tin liên hệ</h4>
                <div class="mb-4">
                    <h5 class="mb-2"><i class="fas fa-map-marker-alt text-primary"></i> Địa chỉ</h5>
                    <p class="text-muted">123 Đường ABC, Quận Đống Đa, Hà Nội, Việt Nam</p>
                </div>
                <div class="mb-4">
                    <h5 class="mb-2"><i class="fas fa-phone text-primary"></i> Điện thoại</h5>
                    <p class="text-muted">
                        <a href="tel:+841234567890" class="text-decoration-none">+84 123 456 789</a><br>
                        <a href="tel:+841987654321" class="text-decoration-none">+84 198 765 432</a>
                    </p>
                </div>
                <div class="mb-4">
                    <h5 class="mb-2"><i class="fas fa-envelope text-primary"></i> Email</h5>
                    <p class="text-muted">
                        <a href="mailto:info@webbanhang.com" class="text-decoration-none">info@webbanhang.com</a><br>
                        <a href="mailto:support@webbanhang.com" class="text-decoration-none">support@webbanhang.com</a>
                    </p>
                </div>
                <div>
                    <h5 class="mb-2"><i class="fas fa-clock text-primary"></i> Giờ làm việc</h5>
                    <p class="text-muted">
                        Thứ 2 - Thứ 7: 8:00 - 20:00<br>
                        Chủ nhật: 10:00 - 18:00
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
